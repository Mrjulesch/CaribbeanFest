# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/caribbean_fest?schema=public"

# JWT
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_ACCESS_TTL="900s"
JWT_REFRESH_SECRET="otro-secreto-distinto"
JWT_REFRESH_TTL="7d"

# App
PORT=3000
CORS_ORIGINS="http://localhost:8080,http://localhost:5173"

# Firebase Cloud Messaging (push). Opcional: si se omite, las notificaciones
# operan en modo log. Pega el JSON de la cuenta de servicio en una sola línea.
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"..."}'

# Correo (aceptación de inscripción + link de pago). Opcional: sin clave = modo log.
# MAIL_FROM="Caribbean Fest <no-reply@tudominio.com>"
# SENDGRID_API_KEY="SG.xxxxx"   # SendGrid: solo verificar un remitente (sin dominio)
# RESEND_API_KEY="re_xxxxx"     # Resend: requiere dominio verificado
